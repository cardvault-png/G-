generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                  String    @id @default(uuid())
  email               String?   @unique
  phone               String?   @unique
  passwordHash        String
  fullName            String
  username            String    @unique
  referralCode        String?
  referredBy          String?
  
  role                String    @default("USER")
  isBanned            Boolean   @default(false)
  banReason           String?
  
  twoFactorSecret     String?
  twoFactorEnabled    Boolean   @default(false)
  twoFactorBackupCodes String?
  
  kycStatus           String    @default("NOT_SUBMITTED")
  kycSubmittedAt      DateTime?
  kycApprovedAt       DateTime?
  kycRejectedAt       DateTime?
  kycRejectionReason  String?
  
  lastLoginAt         DateTime?
  lastLoginIp         String?
  deviceFingerprint   String?
  
  termsAccepted       Boolean   @default(false)
  termsAcceptedAt     DateTime?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  wallets             Wallet[]
  transactions        Transaction[]
  giftCards           GiftCard[]
  kycDocuments        KycDocument[]
  notifications       Notification[]
  loginAttempts       LoginAttempt[]
  auditLogs           AuditLog[]
  adminActions        AdminAction[]
  appeals             Appeal[]
}

model Wallet {
  id            String     @id @default(uuid())
  userId        String
  type          String
  balance       Float      @default(0)
  frozenBalance Float      @default(0)
  address       String?
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  ledgerEntries Ledger[]
  
  @@unique([userId, type])
}

model Transaction {
  id                String   @id @default(uuid())
  userId            String
  walletId          String
  
  type              String
  status            String   @default("PENDING")
  
  amount            Float
  fee               Float    @default(0)
  netAmount         Float
  
  walletType        String
  
  referenceCode     String?
  referralCode      String?
  
  blockchainHash    String?
  networkType       String?
  confirmations     Int      @default(0)
  
  bankName          String?
  accountNumber     String?
  accountName       String?
  bankReference     String?
  
  approvedBy        String?
  adminNotes        String?
  
  fraudScore        Int      @default(0)
  disputeFlag       Boolean  @default(false)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  completedAt       DateTime?
  reversedAt        DateTime?
  
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet            Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  ledgerEntries     Ledger[]
}

model Ledger {
  id              String      @id @default(uuid())
  userId          String
  walletId        String
  transactionId   String
  
  debit           Float?
  credit          Float?
  balanceAfter    Float
  
  description     String?
  createdAt       DateTime    @default(now())
  
  wallet          Wallet      @relation(fields: [walletId], references: [id], onDelete: Cascade)
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model GiftCard {
  id                String   @id @default(uuid())
  userId            String
  
  brand             String
  country           String
  cardValue         Float
  currency          String   @default("USD")
  
  pinCode           String
  
  ocrResult         String?
  ocrConfidence     Float    @default(0)
  
  fraudScore        Int      @default(0)
  reviewCategory    String?
  
  status            String   @default("PENDING")
  
  imageFront        String
  imageBack         String
  imageScratched    String?
  
  rate              Float
  payoutAmount      Float
  
  reviewedBy        String?
  adminNotes        String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  processedAt       DateTime?
  
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KycDocument {
  id              String    @id @default(uuid())
  userId          String
  
  documentType    String
  documentNumber  String?
  
  frontImage      String
  backImage       String?
  selfieImage     String
  
  verifiedAt      DateTime?
  verifiedBy      String?
  rejectionReason String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  
  type        String
  title       String
  message     String
  
  actionUrl   String?
  
  isRead      Boolean  @default(false)
  readAt      DateTime?
  
  emailSent   Boolean  @default(false)
  emailSentAt DateTime?
  
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginAttempt {
  id                String    @id @default(uuid())
  userId            String?
  
  email             String?
  ipAddress         String
  userAgent         String?
  deviceFingerprint String?
  
  success           Boolean
  failureReason     String?
  
  createdAt         DateTime  @default(now())
  
  user              User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model AdminAction {
  id          String    @id @default(uuid())
  adminId     String
  
  actionType  String
  targetType  String
  targetId    String
  
  oldValue    String?
  newValue    String?
  reason      String?
  
  ipAddress   String
  userAgent   String?
  
  createdAt   DateTime  @default(now())
  
  admin       User      @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String    @id @default(uuid())
  userId      String?
  
  action      String
  entityType  String
  entityId    String?
  
  oldData     String?
  newData     String?
  
  ipAddress   String
  userAgent   String?
  
  createdAt   DateTime  @default(now())
  
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Appeal {
  id          String    @id @default(uuid())
  userId      String
  
  subject     String
  message     String
  evidence    String?
  
  status      String    @default("PENDING")
  
  reviewedBy  String?
  adminNotes  String?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  reviewedAt  DateTime?
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpCode {
  id          String    @id @default(uuid())
  
  identifier  String
  code        String
  type        String
  
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  
  expiresAt   DateTime
  usedAt      DateTime?
  
  createdAt   DateTime  @default(now())
}

model CryptoRate {
  id            String    @id @default(uuid())
  
  symbol        String    @unique
  name          String
  priceUsd      Float
  change24h     Float
  volume24h     Float
  marketCap     Float
  
  lastUpdated   DateTime  @default(now())
}

model SystemSetting {
  id          String    @id @default(uuid())
  
  key         String    @unique
  value       String
  description String?
  
  updatedAt   DateTime  @updatedAt
  updatedBy   String?
}

model AdminWallet {
  id          String    @id @default(uuid())
  
  adminId     String    @unique
  balance     Float     @default(15000)
  
  autoRefillEnabled   Boolean @default(true)
  autoRefillAmount    Float   @default(200)
  lastRefillAt        DateTime?
  
  workEmail   String?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model BlockchainMonitor {
  id              String    @id @default(uuid())
  
  userId          String
  walletId        String
  
  txHash          String
  fromAddress     String
  toAddress       String
  amount          Float
  
  network         String
  token           String
  
  confirmations   Int       @default(0)
  requiredConfirmations Int @default(19)
  
  status          String    @default("PENDING")
  
  transactionId   String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  confirmedAt     DateTime?
}

model BankAccount {
  id              String    @id @default(uuid())
  userId          String
  
  country         String
  bankName        String
  bankCode        String?
  accountNumber   String
  accountName     String
  
  isVerified      Boolean   @default(false)
  isDefault       Boolean   @default(false)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model GiftCardRate {
  id              String    @id @default(uuid())
  
  brand           String
  country         String
  currency        String
  
  rate            Float
  
  minAmount       Float
  maxAmount       Float
  
  isActive        Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([brand, country, currency])
}
