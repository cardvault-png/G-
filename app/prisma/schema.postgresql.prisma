generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User roles enum
enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

// Transaction types enum
enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  GIFT_CARD_SALE
  GIFT_CARD_PURCHASE
  TRANSFER_SEND
  TRANSFER_RECEIVE
  FEE
  REVERSAL
  ADMIN_ADJUSTMENT
}

// Transaction status enum
enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
  REVERSED
  UNDER_REVIEW
}

// Wallet types enum
enum WalletType {
  USD
  USDT
  BTC
  ETH
}

// KYC status enum
enum KycStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

// Gift card status enum
enum GiftCardStatus {
  PENDING
  AI_PROCESSING
  AI_APPROVED
  AI_REJECTED
  ADMIN_REVIEW
  APPROVED
  REJECTED
  COMPLETED
}

// Notification types enum
enum NotificationType {
  TRANSACTION
  VERIFICATION
  WITHDRAWAL
  SECURITY
  SYSTEM
  PROMOTION
}

// User model
model User {
  id                  String    @id @default(uuid())
  email               String?   @unique
  phone               String?   @unique
  passwordHash        String    @map("password_hash")
  fullName            String    @map("full_name")
  username            String    @unique
  referralCode        String?   @map("referral_code")
  referredBy          String?   @map("referred_by")
  
  role                UserRole  @default(USER)
  isBanned            Boolean   @default(false) @map("is_banned")
  banReason           String?   @map("ban_reason")
  
  // 2FA
  twoFactorSecret     String?   @map("two_factor_secret")
  twoFactorEnabled    Boolean   @default(false) @map("two_factor_enabled")
  twoFactorBackupCodes String?  @map("two_factor_backup_codes")
  
  // KYC
  kycStatus           KycStatus @default(NOT_SUBMITTED) @map("kyc_status")
  kycSubmittedAt      DateTime? @map("kyc_submitted_at")
  kycApprovedAt       DateTime? @map("kyc_approved_at")
  kycRejectedAt       DateTime? @map("kyc_rejected_at")
  kycRejectionReason  String?   @map("kyc_rejection_reason")
  
  // Device & Security
  lastLoginAt         DateTime? @map("last_login_at")
  lastLoginIp         String?   @map("last_login_ip")
  deviceFingerprint   String?   @map("device_fingerprint")
  
  // Terms acceptance
  termsAccepted       Boolean   @default(false) @map("terms_accepted")
  termsAcceptedAt     DateTime? @map("terms_accepted_at")
  
  // Timestamps
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  
  // Relations
  wallets             Wallet[]
  transactions        Transaction[]
  giftCards           GiftCard[]
  kycDocuments        KycDocument[]
  notifications       Notification[]
  loginAttempts       LoginAttempt[]
  auditLogs           AuditLog[]
  adminActions        AdminAction[]
  appeals             Appeal[]
  
  @@index([email])
  @@index([phone])
  @@index([username])
  @@index([role])
  @@index([isBanned])
  @@index([kycStatus])
  @@map("users")
}

// Wallet model
model Wallet {
  id            String     @id @default(uuid())
  userId        String     @map("user_id")
  type          WalletType
  balance       Decimal    @default(0) @db.Decimal(18, 8)
  frozenBalance Decimal    @default(0) @map("frozen_balance") @db.Decimal(18, 8)
  
  // Crypto wallet addresses
  address       String?    // For crypto deposits
  
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  
  // Relations
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  ledgerEntries Ledger[]
  
  @@unique([userId, type])
  @@index([userId])
  @@index([type])
  @@map("wallets")
}

// Transaction model
model Transaction {
  id                String            @id @default(uuid())
  userId            String            @map("user_id")
  walletId          String            @map("wallet_id")
  
  type              TransactionType
  status            TransactionStatus @default(PENDING)
  
  amount            Decimal           @db.Decimal(18, 8)
  fee               Decimal           @default(0) @db.Decimal(18, 8)
  netAmount         Decimal           @map("net_amount") @db.Decimal(18, 8)
  
  // Currency/Wallet info
  walletType        WalletType        @map("wallet_type")
  
  // Reference codes
  referenceCode     String?           @map("reference_code")
  referralCode      String?           @map("referral_code")
  
  // Blockchain fields
  blockchainHash    String?           @map("blockchain_hash")
  networkType       String?           @map("network_type") // TRC20, BEP20, ERC20
  confirmations     Int               @default(0)
  
  // Bank fields
  bankName          String?           @map("bank_name")
  accountNumber     String?           @map("account_number")
  accountName       String?           @map("account_name")
  bankReference     String?           @map("bank_reference")
  
  // Admin fields
  approvedBy        String?           @map("approved_by")
  adminNotes        String?           @map("admin_notes")
  
  // Fraud detection
  fraudScore        Int               @default(0) @map("fraud_score")
  fraudFlags        String[]          @map("fraud_flags")
  disputeFlag       Boolean           @default(false) @map("dispute_flag")
  
  // Timing
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  completedAt       DateTime?         @map("completed_at")
  reversedAt        DateTime?         @map("reversed_at")
  
  // Relations
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet            Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
  ledgerEntries     Ledger[]
  
  @@index([userId])
  @@index([walletId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([referenceCode])
  @@index([blockchainHash])
  @@map("transactions")
}

// Ledger for immutable accounting
model Ledger {
  id              String      @id @default(uuid())
  userId          String      @map("user_id")
  walletId        String      @map("wallet_id")
  transactionId   String      @map("transaction_id")
  
  debit           Decimal?    @db.Decimal(18, 8)
  credit          Decimal?    @db.Decimal(18, 8)
  balanceAfter    Decimal     @map("balance_after") @db.Decimal(18, 8)
  
  description     String?
  createdAt       DateTime    @default(now()) @map("created_at")
  
  // Relations
  wallet          Wallet      @relation(fields: [walletId], references: [id], onDelete: Cascade)
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([walletId])
  @@index([transactionId])
  @@index([createdAt])
  @@map("ledger")
}

// Gift Card model
model GiftCard {
  id                String         @id @default(uuid())
  userId            String         @map("user_id")
  
  // Card details
  brand             String
  country           String
  cardValue         Decimal        @map("card_value") @db.Decimal(18, 2)
  currency          String         @default("USD")
  
  // PIN (encrypted)
  pinCode           String         @map("pin_code")
  
  // OCR results
  ocrResult         String?        @map("ocr_result")
  ocrConfidence     Float          @default(0) @map("ocr_confidence")
  
  // AI/Fraud detection
  fraudScore        Int            @default(0) @map("fraud_score")
  fraudFlags        String[]       @map("fraud_flags")
  reviewCategory    String?        @map("review_category") // BLURRED, EDITED, DUPLICATE, etc.
  
  // Status
  status            GiftCardStatus @default(PENDING)
  
  // Images
  imageFront        String         @map("image_front")
  imageBack         String         @map("image_back")
  imageScratched    String?        @map("image_scratched")
  
  // Pricing
  rate              Decimal        @db.Decimal(10, 4) // Rate offered
  payoutAmount      Decimal        @map("payout_amount") @db.Decimal(18, 8)
  
  // Admin
  reviewedBy        String?        @map("reviewed_by")
  adminNotes        String?        @map("admin_notes")
  
  // Timing
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  processedAt       DateTime?      @map("processed_at")
  
  // Relations
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([status])
  @@index([brand])
  @@index([createdAt])
  @@map("gift_cards")
}

// KYC Documents model
model KycDocument {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  
  documentType    String    @map("document_type") // PASSPORT, ID_CARD, DRIVERS_LICENSE
  documentNumber  String?   @map("document_number")
  
  // Images
  frontImage      String    @map("front_image")
  backImage       String?   @map("back_image")
  selfieImage     String    @map("selfie_image")
  
  // Verification
  verifiedAt      DateTime? @map("verified_at")
  verifiedBy      String?   @map("verified_by")
  rejectionReason String?   @map("rejection_reason")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@map("kyc_documents")
}

// Notification model
model Notification {
  id          String           @id @default(uuid())
  userId      String           @map("user_id")
  
  type        NotificationType
  title       String
  message     String
  
  // Action link
  actionUrl   String?          @map("action_url")
  
  // Status
  isRead      Boolean          @default(false) @map("is_read")
  readAt      DateTime?        @map("read_at")
  
  // Email tracking
  emailSent   Boolean          @default(false) @map("email_sent")
  emailSentAt DateTime?        @map("email_sent_at")
  
  createdAt   DateTime         @default(now()) @map("created_at")
  
  // Relations
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// Login Attempts (for security)
model LoginAttempt {
  id              String    @id @default(uuid())
  userId          String?   @map("user_id")
  
  email           String?
  ipAddress       String    @map("ip_address")
  userAgent       String?   @map("user_agent")
  deviceFingerprint String? @map("device_fingerprint")
  
  success         Boolean
  failureReason   String?   @map("failure_reason")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  
  // Relations
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@index([userId])
  @@index([ipAddress])
  @@index([createdAt])
  @@map("login_attempts")
}

// Admin Actions Audit Log
model AdminAction {
  id          String    @id @default(uuid())
  adminId     String    @map("admin_id")
  
  actionType  String    @map("action_type") // BAN, UNBAN, APPROVE_KYC, APPROVE_WITHDRAWAL, etc.
  targetType  String    @map("target_type") // USER, TRANSACTION, GIFT_CARD, etc.
  targetId    String    @map("target_id")
  
  oldValue    String?   @map("old_value")
  newValue    String?   @map("new_value")
  reason      String?
  
  ipAddress   String    @map("ip_address")
  userAgent   String?   @map("user_agent")
  
  createdAt   DateTime  @default(now()) @map("created_at")
  
  // Relations
  admin       User      @relation(fields: [adminId], references: [id], onDelete: Cascade)
  
  @@index([adminId])
  @@index([actionType])
  @@index([targetType])
  @@index([targetId])
  @@index([createdAt])
  @@map("admin_actions")
}

// Audit Log (comprehensive system logging)
model AuditLog {
  id          String    @id @default(uuid())
  userId      String?   @map("user_id")
  
  action      String    // CREATE, UPDATE, DELETE, VIEW, etc.
  entityType  String    @map("entity_type") // USER, TRANSACTION, WALLET, etc.
  entityId    String?   @map("entity_id")
  
  oldData     Json?     @map("old_data")
  newData     Json?     @map("new_data")
  
  ipAddress   String    @map("ip_address")
  userAgent   String?   @map("user_agent")
  
  createdAt   DateTime  @default(now()) @map("created_at")
  
  // Relations
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}

// Appeal model (for banned users)
model Appeal {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  
  subject     String
  message     String
  evidence    String?   // File path or URL
  
  status      String    @default("PENDING") // PENDING, REVIEWING, APPROVED, REJECTED
  
  reviewedBy  String?   @map("reviewed_by")
  adminNotes  String?   @map("admin_notes")
  
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  reviewedAt  DateTime? @map("reviewed_at")
  
  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([status])
  @@map("appeals")
}

// OTP Codes (for email/phone verification)
model OtpCode {
  id          String    @id @default(uuid())
  
  identifier  String    // email or phone
  code        String
  type        String    // EMAIL_VERIFICATION, PHONE_VERIFICATION, PASSWORD_RESET, etc.
  
  attempts    Int       @default(0)
  maxAttempts Int       @default(3) @map("max_attempts")
  
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  
  createdAt   DateTime  @default(now()) @map("created_at")
  
  @@index([identifier])
  @@index([code])
  @@index([expiresAt])
  @@map("otp_codes")
}

// Crypto Rates Cache
model CryptoRate {
  id            String    @id @default(uuid())
  
  symbol        String    @unique // BTC, ETH, USDT, etc.
  name          String
  priceUsd      Decimal   @map("price_usd") @db.Decimal(18, 8)
  change24h     Float     @map("change_24h")
  volume24h     Decimal   @map("volume_24h") @db.Decimal(18, 2)
  marketCap     Decimal   @map("market_cap") @db.Decimal(18, 2)
  
  lastUpdated   DateTime  @default(now()) @map("last_updated")
  
  @@index([symbol])
  @@map("crypto_rates")
}

// System Settings
model SystemSetting {
  id          String    @id @default(uuid())
  
  key         String    @unique
  value       String
  description String?
  
  updatedAt   DateTime  @updatedAt @map("updated_at")
  updatedBy   String?   @map("updated_by")
  
  @@map("system_settings")
}

// Admin Wallet (for admin operations)
model AdminWallet {
  id          String    @id @default(uuid())
  
  adminId     String    @unique @map("admin_id")
  balance     Decimal   @default(15000) @db.Decimal(18, 2)
  
  // Auto-refill settings
  autoRefillEnabled   Boolean @default(true) @map("auto_refill_enabled")
  autoRefillAmount    Decimal @default(200) @map("auto_refill_amount") @db.Decimal(18, 2)
  lastRefillAt        DateTime? @map("last_refill_at")
  
  workEmail   String?   @map("work_email")
  
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  
  @@map("admin_wallets")
}

// Blockchain Monitoring (deposits waiting for confirmation)
model BlockchainMonitor {
  id              String    @id @default(uuid())
  
  userId          String    @map("user_id")
  walletId        String    @map("wallet_id")
  
  // Transaction details
  txHash          String    @map("tx_hash")
  fromAddress     String    @map("from_address")
  toAddress       String    @map("to_address")
  amount          Decimal   @db.Decimal(18, 8)
  
  // Network
  network         String    // TRON, BSC, ETH
  token           String    // USDT, USDC, etc.
  
  // Confirmation tracking
  confirmations   Int       @default(0)
  requiredConfirmations Int @default(19) @map("required_confirmations")
  
  // Status
  status          String    @default("PENDING") // PENDING, CONFIRMED, FAILED
  
  // Linked transaction
  transactionId   String?   @map("transaction_id")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  confirmedAt     DateTime? @map("confirmed_at")
  
  @@index([userId])
  @@index([txHash])
  @@index([toAddress])
  @@index([status])
  @@map("blockchain_monitor")
}

// Bank Accounts (for withdrawals)
model BankAccount {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  
  country         String
  bankName        String    @map("bank_name")
  bankCode        String?   @map("bank_code")
  accountNumber   String    @map("account_number")
  accountName     String    @map("account_name")
  
  isVerified      Boolean   @default(false) @map("is_verified")
  isDefault       Boolean   @default(false) @map("is_default")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  @@index([userId])
  @@map("bank_accounts")
}

// Gift Card Rates (admin configurable)
model GiftCardRate {
  id              String    @id @default(uuid())
  
  brand           String
  country         String
  currency        String
  
  // Rate as percentage (e.g., 85 = 85% of card value)
  rate            Decimal   @db.Decimal(5, 2)
  
  minAmount       Decimal   @map("min_amount") @db.Decimal(18, 2)
  maxAmount       Decimal   @map("max_amount") @db.Decimal(18, 2)
  
  isActive        Boolean   @default(true) @map("is_active")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  @@unique([brand, country, currency])
  @@map("gift_card_rates")
}
